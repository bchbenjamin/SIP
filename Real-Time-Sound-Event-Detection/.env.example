# YAMNet Sound Event Detection Config
# Which audio event classes to show in the plot. Comma-separated list of IDs.
YAMNET_CLASSES=0,132,420,494

# Microphone index. Leave empty or commented out to use the default mic.
# MIC_INDEX=0

# Duration in seconds of each audio clip chunk (default: 0.975)
WIN_SIZE_SEC=0.975

# How long to record for in total seconds
RECORD_SECONDS=500
